// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum Category {
  MUSIC
  GAMING
  TALK
  SPORTS
  EDUCATION
  TECH
  COMEDY
  OTHER
}

enum Plan {
  FREE
  STUDIO_PRO
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

model Creator {
  id                  String    @id @default(uuid())
  clerkId             String    @unique // Clark ID
  email               String    @unique
  handle              String    @unique // Unique @ slug
  displayName         String?
  avatarUrl           String?
  bio                 String?
  category            Category?
  
  // Subscription / Plan
  plan                Plan      @default(FREE)
  planStatus          String?
  planPeriodEnd       DateTime?
  subscriptionId      String?
  
  // Stripe Connect & Payments
  stripeCustomerId    String?
  stripeAccountId     String?
  stripeAccountStatus String?
  
  // Streaming (Custom RTMP & Mux)
  rtmpKey             String?   @unique
  rtmpSecret          String?   // Unique RTMP secret
  muxLiveStreamId     String?
  muxStreamKey        String?
  muxAssetId          String?
  
  // AI (Aura)
  auraEnabled         Boolean   @default(false)
  auraVoice           String    @default("onyx")
  auraAutoSummary     Boolean   @default(false)
  
  // Payment Handles (Zero-Fee System)
  paypalHandle        String?
  cashappHandle       String?
  venmoHandle         String?
  zelleHandle         String?
  chimeHandle         String?
  
  // Cross-Platform Streaming Keys (Encrypted)
  instagramStreamKey  String?
  tiktokStreamKey     String?
  facebookStreamKey   String?
  youtubeStreamKey    String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relations
  streams             Stream[]
  watchParties        WatchParty[]
  videoPosts          VideoPost[]
  paymentsReceived    Payment[]      @relation("RecipientPayments")
  subscriptions       Subscription[]
  follows             Follow[]       @relation("Following")
}

model Stream {
  id                  String    @id @default(uuid())
  creatorId           String
  creator             Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  title               String
  description         String?
  category            Category?
  thumbnailUrl        String?
  
  status              StreamStatus @default(SCHEDULED)
  visibility          Visibility   @default(PUBLIC)
  streamKey           String       @default(uuid()) // Internal key for RTMP coordination
  
  // Timestamps
  scheduledAt         DateTime?
  startedAt           DateTime?
  endedAt             DateTime?
  durationSeconds     Int          @default(0)
  
  // Analytics / Metrics
  peakViewers         Int          @default(0)
  totalViewers        Int          @default(0)
  totalMessages       Int          @default(0)
  totalSuperChat      Float        @default(0.0)

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  guests              StreamGuest[]
  relays              RtmpRelay[]
  chatMessages        ChatMessage[]
  payments            Payment[]
}

model RtmpRelay {
  id                  String    @id @default(uuid())
  streamId            String
  stream              Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  platform            String
  status              String    @default("inactive")
  lastError           String?
  connectionStartedAt DateTime?
  connectionEndedAt   DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([streamId, platform])
}

model StreamGuest {
  id                  String    @id @default(uuid())
  streamId            String
  stream              Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId              String
  gridPosition        Int
  status              String    @default("connected")
  joinedAt            DateTime  @default(now())
  leftAt              DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([streamId, userId, gridPosition])
}

model WatchParty {
  id                  String    @id @default(uuid())
  hostId              String
  creator             Creator   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  
  title               String
  description         String?
  videoUrl            String
  videoSource         String    @default("youtube")
  videoId             String
  inviteCode          String    @unique
  visibility          Visibility @default(PUBLIC)
  status              String     @default("active")
  
  currentTimeSeconds  Int        @default(0)
  isPlaying           Boolean    @default(false)
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  
  participants        WatchPartyParticipant[]
}

model WatchPartyParticipant {
  id                  String     @id @default(uuid())
  watchPartyId        String
  watchParty          WatchParty @relation(fields: [watchPartyId], references: [id], onDelete: Cascade)
  userId              String     // Can be a creator or viewer clerkId
  status              String     @default("connected")
  isReady             Boolean    @default(false)
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([watchPartyId, userId])
}

model VideoPost {
  id                  String    @id @default(uuid())
  creatorId           String
  creator             Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  title               String
  description         String?
  videoUrl            String
  thumbnailUrl        String?
  
  price               Float     @default(0.0)
  currency            String    @default("USD")
  isForSale           Boolean   @default(true)
  
  viewsCount          Int       @default(0)
  likesCount          Int       @default(0)
  status              String    @default("active")
  
  // Mux Asset Tracking
  muxAssetId          String?
  muxPlaybackId       String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  purchases           MarketplacePurchase[]
}

model MarketplacePurchase {
  id                  String    @id @default(uuid())
  videoPostId         String
  videoPost           VideoPost @relation(fields: [videoPostId], references: [id], onDelete: Cascade)
  buyerId             String
  sellerId            String
  
  amount              Float
  currency            String    @default("USD")
  
  paymentMethod       String?
  transactionId       String?   @unique
  status              String    @default("completed")
  
  createdAt           DateTime  @default(now())
}

model ChatMessage {
  id                  String    @id @default(uuid())
  streamId            String
  stream              Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId              String    // Can be a creator or viewer clerkId
  message             String
  
  aiModerated         Boolean   @default(false)
  aiConfidence        Float?
  aiAction            String?
  aiReason            String?
  isDeleted           Boolean   @default(false)
  
  createdAt           DateTime  @default(now())
}

model Payment {
  id                  String    @id @default(uuid())
  streamId            String?
  stream              Stream?   @relation(fields: [streamId], references: [id], onDelete: SetNull)
  senderId            String?
  recipientId         String
  recipient           Creator   @relation("RecipientPayments", fields: [recipientId], references: [id], onDelete: Cascade)
  
  amount              Float
  currency            String    @default("USD")
  paymentMethod       String    // paypal, cashapp, venmo, zelle, chime
  
  platformFee         Float     @default(0.0)
  status              String    @default("pending")
  externalTransactionId String?
  
  message             String?
  isAnonymous         Boolean   @default(false)
  
  // Platform Type & Tracking
  type                String?   @default("DONATION") // DONATION, SUBSCRIPTION, MARKETPLACE_PURCHASE
  stripeSessionId     String?   @unique
  userId              String?   // Buyer/Sender ID
  
  createdAt           DateTime  @default(now())
  completedAt         DateTime?
}

model Subscription {
  id                  String    @id @default(uuid())
  creatorId           String
  creator             Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  tier                String    // premium, pro
  
  amount              Float
  currency            String    @default("USD")
  billingCycle        String    @default("monthly")
  
  status              String    @default("active")
  startedAt           DateTime  @default(now())
  expiresAt           DateTime?
  cancelledAt         DateTime?
  
  provider            String?   // stripe, paypal
  providerSubscriptionId String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Follow {
  id                  String    @id @default(uuid())
  followerId          String
  followingId         String
  following           Creator   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime  @default(now())

  @@unique([followerId, followingId])
}
