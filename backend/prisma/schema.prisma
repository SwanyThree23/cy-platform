// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum Category {
  MUSIC
  GAMING
  TALK
  SPORTS
  EDUCATION
  TECH
  COMEDY
  OTHER
}

enum Plan {
  FREE
  STUDIO_PRO
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

model Creator {
  id                  String    @id @default(uuid())
  clerkId             String    @unique @map("clerk_id")
  email               String    @unique
  handle              String    @unique // Unique @ slug
  displayName         String?   @map("display_name")
  avatarUrl           String?   @map("avatar_url")
  bio                 String?
  category            Category?
  
  // Subscription / Plan
  plan                Plan      @default(FREE)
  planStatus          String?   @map("plan_status")
  planPeriodEnd       DateTime? @map("plan_period_end")
  subscriptionId      String?   @map("subscription_id")
  
  // Stripe Connect & Payments
  stripeCustomerId    String?   @map("stripe_customer_id")
  stripeAccountId     String?   @map("stripe_account_id")
  stripeAccountStatus String?   @map("stripe_account_status")
  
  // Streaming (Custom RTMP & Mux)
  rtmpKey             String?   @unique @map("rtmp_key")
  rtmpSecret          String?   @map("rtmp_secret")
  muxLiveStreamId     String?   @map("mux_live_stream_id")
  muxStreamKey        String?   @map("mux_stream_key")
  muxAssetId          String?   @map("mux_asset_id")
  
  // AI (Aura)
  auraEnabled         Boolean   @default(false) @map("aura_enabled")
  auraVoice           String    @default("onyx") @map("aura_voice")
  auraAutoSummary     Boolean   @default(false) @map("aura_auto_summary")
  
  // Payment Handles (Zero-Fee System)
  paypalHandle        String?   @map("paypal_handle")
  cashappHandle       String?   @map("cashapp_handle")
  venmoHandle         String?   @map("venmo_handle")
  zelleHandle         String?   @map("zelle_handle")
  chimeHandle         String?   @map("chime_handle")
  
  // Cross-Platform Streaming Keys (Encrypted)
  instagramStreamKey  String?   @map("instagram_stream_key")
  tiktokStreamKey     String?   @map("tiktok_stream_key")
  facebookStreamKey   String?   @map("facebook_stream_key")
  youtubeStreamKey    String?   @map("youtube_stream_key")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  
  // Relations
  streams             Stream[]
  watchParties        WatchParty[]
  videoPosts          VideoPost[]
  paymentsReceived    Payment[]      @relation("RecipientPayments")
  subscriptions       Subscription[]
  follows             Follow[]       @relation("Following")

  @@map("creators")
}

model Stream {
  id                  String    @id @default(uuid())
  creatorId           String    @map("creator_id")
  creator             Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  title               String
  description         String?
  category            Category?
  thumbnailUrl        String?   @map("thumbnail_url")
  
  status              StreamStatus @default(SCHEDULED)
  visibility          Visibility   @default(PUBLIC)
  streamKey           String       @default(uuid()) @map("stream_key")
  
  // Timestamps
  scheduledAt         DateTime?    @map("scheduled_at")
  startedAt           DateTime?    @map("started_at")
  endedAt             DateTime?    @map("ended_at")
  durationSeconds     Int          @default(0) @map("duration_seconds")
  
  // Analytics / Metrics
  peakViewers         Int          @default(0) @map("peak_viewers")
  totalViewers        Int          @default(0) @map("total_viewers")
  totalMessages       Int          @default(0) @map("total_messages")
  totalSuperChat      Float        @default(0.0) @map("total_super_chat")

  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  guests              StreamGuest[]
  relays              RtmpRelay[]
  chatMessages        ChatMessage[]
  payments            Payment[]

  @@map("streams")
}

model RtmpRelay {
  id                  String    @id @default(uuid())
  streamId            String
  stream              Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  platform            String
  status              String    @default("inactive")
  lastError           String?
  connectionStartedAt DateTime?
  connectionEndedAt   DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([streamId, platform])
}

model StreamGuest {
  id                  String    @id @default(uuid())
  streamId            String
  stream              Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId              String
  gridPosition        Int
  status              String    @default("connected")
  joinedAt            DateTime  @default(now())
  leftAt              DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([streamId, userId, gridPosition])
}

model WatchParty {
  id                  String    @id @default(uuid())
  hostId              String
  creator             Creator   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  
  title               String
  description         String?
  videoUrl            String
  videoSource         String    @default("youtube")
  videoId             String
  inviteCode          String    @unique
  visibility          Visibility @default(PUBLIC)
  status              String     @default("active")
  
  currentTimeSeconds  Int        @default(0)
  isPlaying           Boolean    @default(false)
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  
  participants        WatchPartyParticipant[]
}

model WatchPartyParticipant {
  id                  String     @id @default(uuid())
  watchPartyId        String
  watchParty          WatchParty @relation(fields: [watchPartyId], references: [id], onDelete: Cascade)
  userId              String     // Can be a creator or viewer clerkId
  status              String     @default("connected")
  isReady             Boolean    @default(false)
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([watchPartyId, userId])
}

model VideoPost {
  id                  String    @id @default(uuid())
  creatorId           String
  creator             Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  title               String
  description         String?
  videoUrl            String
  thumbnailUrl        String?
  
  price               Float     @default(0.0)
  currency            String    @default("USD")
  isForSale           Boolean   @default(true)
  
  viewsCount          Int       @default(0)
  likesCount          Int       @default(0)
  status              String    @default("active")
  
  // Mux Asset Tracking
  muxAssetId          String?
  muxPlaybackId       String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  purchases           MarketplacePurchase[]
}

model MarketplacePurchase {
  id                  String    @id @default(uuid())
  videoPostId         String
  videoPost           VideoPost @relation(fields: [videoPostId], references: [id], onDelete: Cascade)
  buyerId             String
  sellerId            String
  
  amount              Float
  currency            String    @default("USD")
  
  paymentMethod       String?
  transactionId       String?   @unique
  status              String    @default("completed")
  
  createdAt           DateTime  @default(now())
}

model ChatMessage {
  id                  String    @id @default(uuid())
  streamId            String
  stream              Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId              String    // Can be a creator or viewer clerkId
  message             String
  
  aiModerated         Boolean   @default(false)
  aiConfidence        Float?
  aiAction            String?
  aiReason            String?
  isDeleted           Boolean   @default(false)
  
  createdAt           DateTime  @default(now())
}

model Payment {
  id                  String    @id @default(uuid())
  streamId            String?
  stream              Stream?   @relation(fields: [streamId], references: [id], onDelete: SetNull)
  senderId            String?
  recipientId         String
  recipient           Creator   @relation("RecipientPayments", fields: [recipientId], references: [id], onDelete: Cascade)
  
  amount              Float
  currency            String    @default("USD")
  paymentMethod       String    // paypal, cashapp, venmo, zelle, chime
  
  platformFee         Float     @default(0.0)
  status              String    @default("pending")
  externalTransactionId String?
  
  message             String?
  isAnonymous         Boolean   @default(false)
  
  // Platform Type & Tracking
  type                String?   @default("DONATION") // DONATION, SUBSCRIPTION, MARKETPLACE_PURCHASE
  stripeSessionId     String?   @unique
  userId              String?   // Buyer/Sender ID
  
  createdAt           DateTime  @default(now())
  completedAt         DateTime?
}

model Subscription {
  id                  String    @id @default(uuid())
  creatorId           String
  creator             Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  tier                String    // premium, pro
  
  amount              Float
  currency            String    @default("USD")
  billingCycle        String    @default("monthly")
  
  status              String    @default("active")
  startedAt           DateTime  @default(now())
  expiresAt           DateTime?
  cancelledAt         DateTime?
  
  provider            String?   // stripe, paypal
  providerSubscriptionId String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Follow {
  id                  String    @id @default(uuid())
  followerId          String
  followingId         String
  following           Creator   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime  @default(now())

  @@unique([followerId, followingId])
}
