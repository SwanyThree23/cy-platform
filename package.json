{
  "name": "cy-platform",
  "version": "1.0.0",
  "private": true,
  "description": "CY Platform - Zero-Fee Live Streaming Beta Launch Suite",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build:all": "cd backend && npm run build && cd ../frontend && npm run build",
    "start": "npm run dev",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd frontend && npm run start\"",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "deploy:hostinger": "bash scripts/deploy-hostinger.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.4",
    "@mux/mux-node": "^12.8.1",
    "@vercel/analytics": "^2.0.1",
    "all": "^0.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "lucide-react": "^0.577.0",
    "mediasoup": "^3.19.18",
    "mediasoup-client": "^3.18.7",
    "react": "^19.2.4",
    "react-player": "^3.4.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^20.4.1"
  }
}
