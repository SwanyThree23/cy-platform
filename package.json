{
  "name": "seewhy-live",
  "version": "1.0.0",
  "private": true,
  "description": "SeeWhy LIVE - 90/10 Split Live Streaming by SwanyThree EntTech",
  "scripts": {
    "dev": "cd frontend && npm run start",
    "start": "cd frontend && npm run start",
    "build": "cd frontend && npm run build",
    "install:all": "cd frontend && npm install",
    "build:all": "cd backend && npm run build && cd ../frontend && npm run build",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "deploy:hostinger": "bash scripts/deploy-hostinger.sh"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.4",
    "lucide-react": "^0.577.0",
    "mediasoup-client": "^3.18.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-player": "^3.4.0",
    "socket.io-client": "^4.8.3"
  }
}
