# Stripe — get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51Svbvv2N0KWn00Qu7HDAR92cb2M446cd6pEDs8CwmswhMowxtfOKRhljIlFOyRrJfddB6GUQrTSYg0WEe4SYmBA900a7dliDKW
