# CY Platform Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://srv1327929.hstgr.cloud
REACT_APP_API_URL=http://srv1327929.hstgr.cloud

# ============================================
# DATABASE (Internal Postgres)
# ============================================
DB_PASSWORD=cy_platform_password_2026
DATABASE_URL=postgresql://cyuser:cy_platform_password_2026@postgres:5432/cyplatform

# ============================================
# DATABASE (Supabase) - Placeholder for cloud or mock
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================
# SECURITY
# ============================================
STREAM_ENCRYPTION_KEY=df876b5c3d2e1f0a9b8c7d6e5f4a3b2c1d0e9f8a7b6c5d4e3f2a1b0c9d8e7f
JWT_SECRET=super_secret_jwt_key_cy_platform_2026

# ============================================
# MEDIASOUP WEBRTC SFU
# ============================================
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=srv1327929.hstgr.cloud

# ============================================
# AI MODERATION (OpenRouter)
# ============================================
OPENROUTER_API_KEY=your-openrouter-api-key
LLM_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# RTMP STREAMING (Optional - for external RTMP ingestion)
# ============================================
RTMP_PORT=1935
RTMP_CHUNK_SIZE=4096

# ============================================
# PAYMENT LINKS (Zero-Fee System)
# These are URL templates for direct payments
# ============================================
PAYPAL_URL_TEMPLATE=https://paypal.me/{handle}
CASHAPP_URL_TEMPLATE=https://cash.app/{handle}
VENMO_URL_TEMPLATE=https://venmo.com/{handle}
ZELLE_INFO_TEMPLATE=Zelle payments go to: {handle}
CHIME_URL_TEMPLATE=https://chime.com/{handle}

# ============================================
# PLATFORM STREAMING ENDPOINTS
# ============================================
INSTAGRAM_RTMP_URL=rtmps://live-upload.instagram.com:443/rtmp/
TIKTOK_RTMP_URL=rtmp://push-rtmp-f5-tt02.tiktokcdn.com/stage/
FACEBOOK_RTMP_URL=rtmps://live-api-s.facebook.com:443/rtmp/
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2/

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_PORT=9090
