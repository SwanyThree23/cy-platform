# CY Platform - Environment Variables
# Copy this file to backend/.env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE (Supabase)
# Get these from your Supabase dashboard: https://app.supabase.io
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alternative: Direct PostgreSQL connection
DATABASE_URL=postgresql://cyuser:password@localhost:5432/cyplatform

# ============================================
# SECURITY
# Generate strong keys: openssl rand -hex 32
# ============================================
STREAM_ENCRYPTION_KEY=your-256-bit-encryption-key-here-change-in-production
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long

# ============================================
# MEDIASOUP WEBRTC SFU
# For local development, use 127.0.0.1
# For production, use your server's public IP
# ============================================
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# ============================================
# AI MODERATION (OpenRouter)
# Get API key: https://openrouter.ai/keys
# ============================================
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
LLM_MODEL=anthropic/claude-3.5-sonnet
# Alternative models:
# LLM_MODEL=openai/gpt-4
# LLM_MODEL=google/gemini-pro
# LLM_MODEL=meta-llama/llama-3.1-70b

# ============================================
# REDIS (Optional - for production)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# AWS (Optional - for S3 storage)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cy-platform-uploads

# ============================================
# PAYMENT PROCESSING (Stripe for subscriptions)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn

# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX
